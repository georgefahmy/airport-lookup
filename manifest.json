{
    "manifest_version": 3,
    "name": "Airport Tooltips",
    "version": "1.2",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "description": "Identifies global airport codes using OurAirports data with a toggle menu.",
    "permissions": [
        "storage",
        "activeTab",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "https://davidmegginson.github.io/"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "airports.json"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}